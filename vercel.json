{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "prisma migrate deploy && prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": [
    "fra1"
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-views",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/health",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/db-sync",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/agent-poll",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}