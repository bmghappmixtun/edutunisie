# Database
# For local dev: use the docker-compose.yml (Postgres container) OR a free Neon/Supabase URL
# For production (Vercel): set this in Vercel dashboard
DATABASE_URL="postgresql://edutunisie:edutunisie@localhost:5432/edutunisie?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-32-char-string"

# File uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_xxxxx"

# Email (Resend) - optional
RESEND_API_KEY="re_xxxxx"

# Storage
UPLOAD_DIR="./public/uploads"
