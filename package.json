{
  "name": "examanet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && bash scripts/ensure-search.sh && next build",
    "start": "next start -p 3000",
    "lint": "next lint --dir src",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/postgres-seed.ts",
    "db:studio": "prisma studio",
    "setup": "prisma generate && prisma db push && tsx scripts/postgres-seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "BASE_URL=https://examanet.com playwright test",
    "postinstall": "prisma generate || true",
    "lint:fix": "next lint --dir src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,mjs}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,mjs}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@googleapis/searchconsole": "^6.0.1",
    "@googleapis/webmasters": "^4.0.0",
    "@ilovepdf/ilovepdf-nodejs": "^0.3.1",
    "@prisma/client": "^5.18.0",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@types/pg": "^8.20.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "lucide-react": "^0.408.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.0.7",
    "next": "14.2.35",
    "next-auth": "4.24.14",
    "nuqs": "^2.9.0",
    "pdfjs-dist": "^4.8.69",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-pdf": "^9.0.0",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/lib-storage": "^3.1083.0",
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.4.39",
    "prettier": "^3.9.5",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
