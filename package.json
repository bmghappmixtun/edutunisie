{
  "name": "edutunisie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && bash scripts/ensure-search.sh && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/postgres-seed.ts",
    "db:studio": "prisma studio",
    "setup": "prisma generate && prisma db push && tsx scripts/postgres-seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "BASE_URL=https://edutunisie.vercel.app playwright test",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@ilovepdf/ilovepdf-nodejs": "^0.3.1",
    "@prisma/client": "^5.18.0",
    "@types/pg": "^8.20.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/og": "^0.11.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.408.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.0.7",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "next-intl": "^3.17.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-pdf": "^9.0.0",
    "recharts": "^2.12.7",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}

